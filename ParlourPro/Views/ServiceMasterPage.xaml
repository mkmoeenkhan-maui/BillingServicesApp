<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ParlourPro.Views.ServiceMasterPage"
             xmlns:vm="clr-namespace:ParlourPro.ViewModels"
             xmlns:models="clr-namespace:ParlourPro.Models"
             x:DataType="vm:ServiceMasterViewModel"
             Title="Manage Services"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBG}, Dark={StaticResource PageBG_Dark}}">
    <Grid RowDefinitions="Auto, Auto,*" Padding="20" RowSpacing="20">
        <HorizontalStackLayout Grid.Row="0" Spacing="15" Padding="15" BackgroundColor="{StaticResource Primary}">
            <Frame HeightRequest="40" WidthRequest="40" CornerRadius="20" Padding="0" BorderColor="LightGray" VerticalOptions="Start">
                <Image Source="bizzbilllogo1.png" Aspect="AspectFill"/>
            </Frame>
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="Biz Bill" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Quick &amp; Smart Billing | Services &amp; Academy Manager" FontSize="12" TextColor="White" Opacity="0.8"/>
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <Frame Grid.Row="1" Style="{StaticResource FormCard}" BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Add New Service" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}" FontSize="18"/>

                <Entry Placeholder="Service Name (e.g., Hydra Facial)" 
                       Text="{Binding NewServiceName}" 
                       Style="{StaticResource ModernEntry}" />

                <Entry Placeholder="Rate (₹)" 
                       Keyboard="Numeric" 
                       Text="{Binding NewServiceRate}" 
                       Style="{StaticResource ModernEntry}" />

                <Button Text="Save to Cloud" 
                        Command="{Binding AddServiceCommand}" 
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" HeightRequest="50" CornerRadius="10">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="Text" Value="Saving..."/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="2" ItemsSource="{Binding MasterServices}">
            <CollectionView.Header>
                <Label Text="Active Service Menu" FontAttributes="Bold" Margin="0,10" FontSize="16"/>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ServiceItem">
                    <Frame Margin="0,5" Padding="12" CornerRadius="10" HasShadow="False"
               BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}">

                        <Grid ColumnDefinitions="*, 80, 50" VerticalOptions="Center">

                            <Label Text="{Binding Name}" 
                       VerticalOptions="Center" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       LineBreakMode="TailTruncation"
                       Grid.Column="0"/>

                            <Label Grid.Column="1" 
                       Text="{Binding Price, StringFormat='₹{0}'}" 
                       VerticalOptions="Center"
                       HorizontalOptions="End"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}" 
                       FontSize="16" 
                       FontAttributes="Bold"/>

                            <Button Grid.Column="2"
                        Text="🗑"                                        
                        FontSize="18"
                        BackgroundColor="Transparent" 
                        TextColor="Crimson"
                        WidthRequest="40"
                        HeightRequest="40"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"
                        Padding="0"
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ServiceMasterViewModel}}, Path=DeleteServiceCommand}"
                        CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50">
                    <Label Text="No services added yet!" HorizontalTextAlignment="Center" Opacity="0.5"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="3" IsRunning="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Color="{StaticResource Primary}"/>
    </Grid>
</ContentPage>