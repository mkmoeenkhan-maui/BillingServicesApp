<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ParlourPro.Views.ServiceMasterPage"
             xmlns:vm="clr-namespace:ParlourPro.ViewModels"
             xmlns:models="clr-namespace:ParlourPro.Models"
             x:DataType="vm:ServiceMasterViewModel"
             Title="Manage Services"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBG}, Dark={StaticResource PageBG_Dark}}">
    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="20">

        <Frame Style="{StaticResource FormCard}" BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Add New Service" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}" FontSize="18"/>

                <Entry Placeholder="Service Name (e.g., Hydra Facial)" 
                       Text="{Binding NewServiceName}" 
                       Style="{StaticResource ModernEntry}" />

                <Entry Placeholder="Rate (₹)" 
                       Keyboard="Numeric" 
                       Text="{Binding NewServiceRate}" 
                       Style="{StaticResource ModernEntry}" />

                <Button Text="Save to Cloud" 
                        Command="{Binding AddServiceCommand}" 
                        BackgroundColor="{StaticResource Primary}" 
                        TextColor="White" HeightRequest="50" CornerRadius="10">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="Text" Value="Saving..."/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1" ItemsSource="{Binding MasterServices}">
            <CollectionView.Header>
                <Label Text="Active Service Menu" FontAttributes="Bold" Margin="0,10" FontSize="16"/>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ServiceItem">
                    <Frame Margin="0,5" Padding="15" BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}" Opacity="0.9">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <Label Text="{Binding Name}" VerticalOptions="Center" FontSize="16" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Text="{Binding Price, StringFormat='₹{0}'}" 
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}" FontSize="18" FontAttributes="Bold"/>
                            
                            <ImageButton Grid.Column="2"
                                 Source="delete_icon.png" 
                                 HeightRequest="25"
                                 WidthRequest="25"
                                 VerticalOptions="Center"
                                 Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ServiceMasterViewModel}}, Path=DeleteServiceCommand}"
                                 CommandParameter="{Binding .}">
                                <ImageButton.Behaviors>
                                    <toolkit:IconTintColorBehavior TintColor="Crimson" />
                                </ImageButton.Behaviors>
                            </ImageButton>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,50">
                    <Label Text="No services added yet!" HorizontalTextAlignment="Center" Opacity="0.5"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="2" IsRunning="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" Color="{StaticResource Primary}"/>
    </Grid>
</ContentPage>