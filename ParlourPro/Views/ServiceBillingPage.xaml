        <Border x:Name="ReceiptView" 
        IsVisible="False" 
        BackgroundColor="White" 
        WidthRequest="350" 
        Padding="20"
        VerticalOptions="Start" 
        HorizontalOptions="Center">

            <VerticalStackLayout Spacing="8">
                <Label Text="Biz Bill" HorizontalOptions="Center" FontAttributes="Bold" FontSize="20" TextColor="Black"/>
                <Label Text="Quick &amp; Smart Billing | Services &amp; Academy Manager" HorizontalOptions="Center" FontSize="10" TextColor="Black"/>
                <BoxView HeightRequest="1" Color="Black" Margin="0,5"/>

                <Label Text="{Binding CurrentBillNumber, StringFormat='Bill No: {0}'}" HorizontalOptions="Center" TextColor="Black" FontSize="12"/>
                <Label Text="{Binding CustomerName, StringFormat='Customer: {0}'}" TextColor="Black" FontSize="12"/>
                <Label Text="{Binding Mobile, StringFormat='Mobile: {0}'}" TextColor="Black" FontSize="12"/>
                <Label Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='Date: {0:dd/MM/yyyy HH:mm}'}" FontSize="10" TextColor="Black"/>

                <BoxView HeightRequest="1" Color="Black" Margin="0,5"/>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding CurrentBillItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:ServiceItem">
                            <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                <Label Text="{Binding Name}" TextColor="Black" FontSize="12"/>
                                <Label Grid.Column="1" Text="{Binding Price, StringFormat='₹{0}'}" TextColor="Black" FontSize="12"/>

                                <!--<ImageButton Grid.Column="2" Source="delete_icon.png" HeightRequest="20"
                                     Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ServiceBillingViewModel}}, Path=DeleteCartItemCommand}"
                                     CommandParameter="{Binding .}">
                                    <ImageButton.Behaviors>
                                        <toolkit:IconTintColorBehavior TintColor="Crimson" />
                                    </ImageButton.Behaviors>
                                </ImageButton>-->
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="Black" Margin="0,5"/>

                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="Grand Total" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                    <Label Grid.Column="1" Text="{Binding FinalTotal, StringFormat='₹{0}'}" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                </Grid>

                <Label Text="--- Visit Again ---" HorizontalOptions="Center" Margin="0,15,0,0" FontSize="10" TextColor="Black"/>
            </VerticalStackLayout>
        </Border>
