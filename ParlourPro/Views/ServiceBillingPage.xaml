    <Grid RowDefinitions="Auto, *" Padding="0">

        <HorizontalStackLayout Grid.Row="0" Spacing="15" Padding="15" BackgroundColor="{StaticResource Primary}">
            <Frame HeightRequest="40" WidthRequest="40" CornerRadius="20" Padding="0" BorderColor="LightGray" VerticalOptions="Start">
                <Image Source="bizzbilllogo1.png" Aspect="AspectFill"/>
            </Frame>
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="Biz Bill" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Quick &amp; Smart Billing | Services &amp; Academy Manager" FontSize="12" TextColor="White" Opacity="0.8"/>
            </VerticalStackLayout>
        </HorizontalStackLayout>

