                <Frame Style="{StaticResource FormCard}" Margin="0,10">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Taxes &amp; Offers" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Discount (₹)" FontSize="12" Opacity="0.7"/>
                                <Entry Text="{Binding Discount}" 
                   Keyboard="Numeric" 
                   Placeholder="0" 
                   Style="{StaticResource ModernEntry}"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="GST Rate (%)" FontSize="12" Opacity="0.7"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Entry Text="{Binding GstRate}" 
                       Keyboard="Numeric" 
                       IsEnabled="{Binding IsGstEnabled}"
                       Style="{StaticResource ModernEntry}"/>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding IsGstEnabled}" Color="{StaticResource Primary}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <Frame BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark=#330015}" BorderColor="{StaticResource Primary}">
                    <HorizontalStackLayout HorizontalOptions="End" Spacing="20">
                        <Label Text="Total Amount:" VerticalOptions="Center" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                        <Label Text="{Binding FinalTotal, StringFormat='₹{0:N0}'}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryText_Dark}}"/>
                    </HorizontalStackLayout>
                </Frame>

                <Button Text="Save Bill &amp; WhatsApp" 
                Command="{Binding SaveAndPrintCommand}" 
                CommandParameter="{x:Reference ReceiptView}"
                BackgroundColor="{StaticResource Primary}" 
                TextColor="White" 
                HeightRequest="55"
                CornerRadius="10"
                FontAttributes="Bold"/>               

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
    
